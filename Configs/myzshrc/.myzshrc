## Shell Options
# turn off flow control
[[ $- == *i* ]] && stty -ixon

# better history completion. type abc and try M-p or M-n
bindkey "\ep" history-beginning-search-backward
bindkey "\en" history-beginning-search-forward

# Give the change to further modify the command from history expansion
setopt histverify
# Append the time of when the command was invoked
HISTTIMEFORMAT="%F %T  "
# Carry all histories from one session to another
export PROMPT_COMMAND="history -a; history -c; history -r; $PROMPT_COMMAND"
# enlarge history size
HISTSIZE=2000
HISTFILESIZE=4000

## Sourcing
[ -f ~/.mytmux.sh ] && source ~/.mytmux.sh
[ -f ~/.myfzf.sh ] && source ~/.myfzf.sh
[ -f ~/.local/share/fzf-git.sh/fzf-git.sh ] && source ~/.local/share/fzf-git.sh/fzf-git.sh

## Custom Functions
# Git stuff, borrowed from oh-my-zsh
git_current_branch() {
    local ref
    ref=$(git symbolic-ref --quiet HEAD 2>/dev/null)
    local ret="$?"
    if [ $ret -ne 0 ] ; then
        [ $ret -eq 128 ] && return # no git repo.
        ref=$(git rev-parse --short HEAD 2>/dev/null) || return
    fi
    echo ${ref#refs/heads/}
}

# given a commit, find immediate children of that commit.
git_children_of() {
    for arg in "$@"; do
      for commit in $(git rev-parse $arg^0); do
        for child in $(git log --format='%H %P' | grep -F " $commit" | cut -f1 -d' '); do
          echo "$child"
        done
      done
    done
}

## PATH env
# for doom
export PATH="$HOME/.config/emacs/bin:$PATH"

## Aliases
alias ewq='emacs &'
alias ec='emacsclient --no-wait '
# alternatives: view
alias cnvim='nvim -u NONE -N -R "+set ignorecase smartcase"'
alias fd='fdfind'
alias bat='batcat'
